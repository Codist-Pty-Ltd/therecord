# ---------------------------------------------------------------------------
# The Record — root .gitignore
# ---------------------------------------------------------------------------

# Dependencies
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/install-state.gz

# Environment variables — NEVER commit
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
**/.env
**/.env.local
**/.env.*.local

# Next.js (apps/web)
.next/
**/.next/
out/
**/out/
next-env.d.ts

# Build / compiled output
dist/
**/dist/
build/
**/build/
*.tsbuildinfo
**/*.tsbuildinfo

# NestJS (apps/api)
.nest/

# Python (apps/intelligence)
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
**/.venv/
**/venv/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Coverage / test output
coverage/
**/coverage/
*.lcov
.nyc_output/

# Caches
.cache/
.turbo/
.eslintcache
.stylelintcache
.parcel-cache/

# IDE / editor
.vscode/*
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Docker
.docker/

# Database
*.sqlite
*.sqlite3
*.db
postgres-data/

# Misc
*.pem
*.key
.vercel
