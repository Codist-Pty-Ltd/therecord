# ---------------------------------------------------------------------------
# The Record — environment template
# Copy this file to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# --- PostgreSQL ------------------------------------------------------------
# Inside docker-compose the hostname is `postgres` (service name).
# For local (non-docker) development, override with host=localhost.
#
# IMPORTANT: the password in DATABASE_URL MUST match POSTGRES_PASSWORD below
# (both are read from this file by docker-compose at startup).
POSTGRES_USER=therecord
POSTGRES_PASSWORD=changeme
POSTGRES_DB=therecord_db
DATABASE_URL=postgresql://therecord:changeme@postgres:5432/therecord_db

# --- Service Ports ---------------------------------------------------------
# Next.js frontend (apps/web) — exposed via nginx in production.
NEXTJS_PORT=3090
# NestJS API (apps/api) — internal orchestration layer.
NESTJS_PORT=3091
# Python FastAPI intelligence service (apps/intelligence) — NLP / AI.
INTELLIGENCE_PORT=8001

# --- Web app (apps/web) ----------------------------------------------------
# Server-side URL used by Next.js RSC / route handlers to reach the NestJS API.
# Inside docker-compose the hostname is `api` (service name).
API_URL=http://api:3091
# Public URL used by the browser — set to the external host in production.
NEXT_PUBLIC_API_URL=http://localhost:3091

# --- Intelligence (apps/api → apps/intelligence) ---------------------------
# Server-to-server URL used by NestJS to reach the FastAPI NLP service.
# Inside docker-compose the hostname is `intelligence` (service name).
INTELLIGENCE_URL=http://intelligence:8001
# Hard ceiling on how long the API will wait for a single intelligence call.
INTELLIGENCE_TIMEOUT_MS=30000

# --- Anthropic (used by apps/intelligence only) ----------------------------
ANTHROPIC_API_KEY=

# --- Ingestion scheduler (apps/api → IngestionSchedulerService) ------------
# Master switch for the @Cron-driven RSS poller (Daily Maverick, News24,
# amaBhungane, every 15 minutes). Set to "true" to arm the scheduler in
# this environment; anything else (or unset) leaves it idle so test or
# CI runs never accidentally hit publishers or the intelligence service.
INGESTION_ENABLED=false
# Secret for `x-ingestion-key` on POST /api/ingestion/* (not required for GET /api/ingestion/intelligence/health). Generate a UUID in production.
INGESTION_API_KEY=

# --- Operator health (GET /api/health/full) ---------------------------------
# Secret for `x-health-key` on GET /api/health/full. Keep long and random; never expose publicly.
HEALTH_API_KEY=
# Ingestion staleness: full health flags `is_stale` when there has been no new article in this many hours.
STALE_THRESHOLD_HOURS=4
