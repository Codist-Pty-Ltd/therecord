{
  "name": "@therecord/api",
  "version": "0.1.0",
  "private": true,
  "description": "The Record — NestJS orchestration API (apps/api).",
  "license": "UNLICENSED",
  "author": "Codist <hello@codist.co.za>",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:smoke": "jest src/test/smoke.spec.ts --forceExit",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate -d src/database/data-source.ts",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:run": "npm run typeorm -- migration:run -d src/database/data-source.ts",
    "migration:run:prod": "node dist/database/run-migrations.js",
    "migration:revert": "npm run typeorm -- migration:revert -d src/database/data-source.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/database/data-source.ts",
    "schema:sync": "npm run typeorm -- schema:sync -d src/database/data-source.ts",
    "schema:drop": "npm run typeorm -- schema:drop -d src/database/data-source.ts",
    "seed": "ts-node src/database/seeds/mkhwanazi.seed.ts",
    "seed:commissions": "ts-node src/database/seeds/commissions-master.seed.ts",
    "seed:reports": "ts-node src/database/seeds/reports.seed.ts",
    "seed:recommendations": "ts-node src/database/seeds/recommendations.seed.ts",
    "seed:adhoc": "ts-node src/database/seeds/adhoc-committees.seed.ts",
    "seed:siu": "ts-node src/database/seeds/siu.seed.ts",
    "seed:all": "ts-node src/database/seeds/index.ts",
    "seed:cape-town": "node dist/database/seeds/cape-town-stories.seed.js",
    "seed:accountability-bodies": "node dist/database/seeds/accountability-bodies.seed.js",
    "db:bootstrap": "npm run schema:sync && npm run seed:all",
    "db:reset": "npm run schema:drop && npm run schema:sync && npm run seed:all"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.9",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.9",
    "@nestjs/platform-express": "^10.3.9",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rss-parser": "^3.13.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s", "!**/*.spec.ts"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "testTimeout": 120000
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.2",
    "@nestjs/testing": "^10.3.9",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/supertest": "^6.0.2",
    "@types/pg": "^8.11.6",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
