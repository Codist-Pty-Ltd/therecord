# ---------------------------------------------------------------------------
# Keep the Docker build context small, especially for the web image (which
# uses the monorepo root as context).
# ---------------------------------------------------------------------------

# Node
**/node_modules
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Next.js
**/.next
**/out

# NestJS / TypeScript build output
**/dist
**/*.tsbuildinfo

# Python
**/__pycache__
**/*.pyc
**/.venv
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache

# Env — NEVER ship host env files into the image
.env
.env.*
!.env.example

# IDE / OS
.git
.gitignore
.github
.vscode
.idea
**/.DS_Store
**/Thumbs.db

# Misc
**/coverage
**/.turbo
**/*.log
