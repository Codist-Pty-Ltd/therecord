{
  "name": "therecord",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "description": "The Record — South African legal intelligence and news timeline platform (Codist).",
  "author": "Codist <hello@codist.co.za>",
  "license": "UNLICENSED",
  "homepage": "https://therecord.codist.co.za",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codist-co-za/therecord.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.2.4"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:docker": "docker compose up",
    "dev:build": "docker compose up --build",
    "dev:down": "docker compose down",
    "prod:up": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    "prod:down": "docker compose -f docker-compose.yml -f docker-compose.prod.yml down",
    "dev:web": "npm run dev --workspace=@therecord/web",
    "dev:api": "npm run start:dev --workspace=@therecord/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@therecord/web",
    "build:api": "turbo run build --filter=@therecord/api",
    "build:shared": "turbo run build --filter=@the-record/shared-types",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "ci": "turbo run typecheck lint",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "turbo": "^2.9.18"
  }
}
