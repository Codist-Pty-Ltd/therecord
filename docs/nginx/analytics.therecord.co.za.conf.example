# The Record — Umami analytics subdomain (copy to VPS nginx sites-enabled)
#
# Prerequisites:
#   - DNS A record: analytics.therecord.co.za → 65.109.7.45
#   - Umami running: docker compose up -d umami umami-db (host port 127.0.0.1:3095)
#   - TLS: certbot --nginx -d analytics.therecord.co.za
#
# Default Umami login after first boot: admin / umami — change immediately.

server {
    listen 443 ssl http2;
    server_name analytics.therecord.co.za;

    ssl_certificate /etc/letsencrypt/live/therecord.co.za/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/therecord.co.za/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:3095;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
